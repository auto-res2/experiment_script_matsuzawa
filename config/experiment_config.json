{
    "training": {
        "epochs": 5,
        "batch_size": 32,
        "learning_rate": 1e-4,
        "weight_decay": 0.01,
        "log_interval": 1,
        "save_interval": 1,
        "optimizer": "AdamW",
        "scheduler": "linear_with_warmup",
        "warmup_steps": 100,
        "test_run": true
    },
    "evaluation": {
        "multimodal_instruction": {
            "num_samples": 2,
            "sample_types": ["description", "color_analysis"]
        },
        "long_context": {
            "token_lengths": [2000, 8000, 10000],
            "num_runs": 1
        },
        "on_device_inference": {
            "iterations": 20,
            "warmup_iterations": 3
        }
    },
    "device": {
        "gpu_type": "NVIDIA Tesla T4",
        "vram": "16GB"
    }
}
